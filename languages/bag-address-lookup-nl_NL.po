msgstr "BAG API gaf status %d terug."

#: src/Api/BagClient.php:64
msgid "Address not found."
msgstr "Adres niet gevonden."

#: src/Checkout/Fields.php:28
msgid "House number"
msgstr "Huisnummer"

#: src/Checkout/BlockIntegration.php:54
msgid "Street and city are filled automatically."
msgstr "Straat en plaats worden automatisch ingevuld."

#: src/Checkout/BlockIntegration.php:55
msgid "Looking up address…"
msgstr "Adres opzoeken…"

#: src/Checkout/BlockIntegration.php:56
msgid "Address not found. Please enter manually."
msgstr "Adres niet gevonden. Vul het handmatig in."

#: src/Checkout/BlockIntegration.php:57
msgid "Address"
msgstr "Adres"

#: src/Checkout/BlockIntegration.php:58
msgid "Edit"
msgstr "Wijzig"

#: src/Checkout/BlockIntegration.php:59
#: src/Checkout/Validation.php:38
msgid "Please include a house number in your address."
msgstr "Vul een huisnummer in bij je adres."

#: src/Plugin.php:29
msgid "Settings"
msgstr "Instellingen"

#: src/Plugin.php:57
#, php-format
msgid "When a customer enters a Dutch postcode and house number during checkout, this data is sent to the Kadaster BAG API to retrieve the street name and city. No other personal data is transmitted. Results are cached on your server for 24 hours. See the %s."
msgstr "Wanneer een klant een postcode en huisnummer invoert bij het afrekenen, worden deze gegevens naar de Kadaster BAG API gestuurd om de straatnaam en woonplaats op te halen. Er worden geen andere persoonsgegevens verzonden. Resultaten worden 24 uur op je server gecacht. Zie het %s."

#: src/Plugin.php:58
msgid "Kadaster privacy policy"
msgstr "Kadaster privacybeleid"

#. Plugin Name of the plugin
msgid "Dutch Address Lookup for WooCommerce (BAG API)"
msgstr "Dutch Address Lookup for WooCommerce (BAG API)"

#. Description of the plugin
msgid "Auto-fills street and city in WooCommerce Block Checkout based on Dutch postcode and house number using the free Kadaster BAG API."
msgstr "Vult automatisch straat en plaats in bij de WooCommerce Block Checkout op basis van postcode en huisnummer via de gratis Kadaster BAG API."
